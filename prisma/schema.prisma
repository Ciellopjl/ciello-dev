// This is your Prisma schema file for the Portfolio Admin Panel
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ─── Portfolio Project ────────────────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  features    String[]
  techs       String[]
  liveUrl     String?
  githubUrl   String?
  imageUrl    String
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Activity Log (Audit) ───────────────────────────────────────────────────────
model ActivityLog {
  id           String   @id @default(cuid())
  action       String   // "CREATE" | "UPDATE" | "DELETE" | "TOGGLE_PUBLISH"
  projectId    String
  projectTitle String
  createdAt    DateTime @default(now())
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
